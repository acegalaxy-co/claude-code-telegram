# telegram-claude-bridge — config
# Copy to .env (git-ignored) and fill in.

# ── Required ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# REQUIRED: comma-separated chat IDs allowed to talk to the bot.
# Find your chat ID: send /start to @userinfobot.
# Bot refuses to start without this — set TELEGRAM_ALLOW_ANY_CHAT=true to opt out (insecure).
TELEGRAM_ALLOWED_CHAT_IDS=
# Explicit opt-out for the allowlist requirement. Default false. Do NOT enable in production.
TELEGRAM_ALLOW_ANY_CHAT=false

# ── Projects (multi-project switching) ────────────────────────
# Directory containing checked-out projects. Each subdir = one switchable target.
# Default: ./projects (relative to where you run telegram-claude-bridge).
# Each project may carry its own .claude/ harness (CLAUDE.md, agents, commands, hooks).
PROJECTS_ROOT=
# Optional: subdir name to auto-select on /new. Example: alpha
DEFAULT_PROJECT=

# ── Claude CLI (default) ──────────────────────────────────────
# Optional: pass --model to claude. Examples: sonnet, opus, haiku, or full id.
CLAUDE_MODEL=
# Optional: single-cwd fallback if PROJECTS_ROOT not set / empty.
CLAUDE_CWD=

# ── Voice STT (Whisper, optional) ─────────────────────────────
# Set to enable voice messages → Whisper transcription → confirm → dispatch.
OPENAI_API_KEY=
# Optional: Whisper model. Default: whisper-1
WHISPER_MODEL=
# Optional: language hint (BCP-47). Examples: vi, en. Leave empty = auto-detect.
VOICE_LANGUAGE=
